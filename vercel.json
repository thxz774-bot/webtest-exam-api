{
  "buildCommand": "pip install -r requirements.txt",
  "framework": "python",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.11",
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/BaseFrontEnd/$1"
    }
  ]
}
